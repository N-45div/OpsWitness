<form version="1.1" theme="dark">
  <label>OpsWitness Evidence Operations</label>
  <description>Splunk-native visibility into AI agent investigations, risky searches, incidents, and approvals.</description>
  <fieldset submitButton="false">
    <input type="time" token="time">
      <label>Time range</label>
      <default>
        <earliest>-24h@h</earliest>
        <latest>now</latest>
      </default>
    </input>
  </fieldset>
  <row>
    <panel>
      <single>
        <title>Agent tool calls</title>
        <search>
          <query>sourcetype="opswitness:event" event_type="mcp.tool.called" | stats count</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
      </single>
    </panel>
    <panel>
      <single>
        <title>Incidents</title>
        <search>
          <query>sourcetype="opswitness:event" event_type="incident.detected" | stats count</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
      </single>
    </panel>
    <panel>
      <single>
        <title>Human decisions</title>
        <search>
          <query>sourcetype="opswitness:event" event_type IN ("human.approval.approved","human.approval.rejected") | stats count</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
      </single>
    </panel>
  </row>
  <row>
    <panel>
      <chart>
        <title>Agent activity by event type</title>
        <search>
          <query>sourcetype="opswitness:event" | timechart span=5m count by event_type limit=10</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="charting.chart">line</option>
      </chart>
    </panel>
    <panel>
      <table>
        <title>Risky searches and evidence</title>
        <search>
          <query>sourcetype="opswitness:event" event_type IN ("splunk.search.generated","splunk.search.executed") | search risk_tags IN ("*broad-search*","*raw-export*","*sensitive-index*") | table _time run_id agent_id event_type risk_tags payload | sort - _time</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
      </table>
    </panel>
  </row>
  <row>
    <panel>
      <table>
        <title>Incident and approval trail</title>
        <search>
          <query>sourcetype="opswitness:event" event_type IN ("deployment.recorded","incident.detected","remediation.proposed","human.approval.approved","human.approval.rejected") | table _time run_id event_type agent_id payload | sort - _time</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
      </table>
    </panel>
  </row>
</form>
