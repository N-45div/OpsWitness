OPSWITNESS_STORE_DIR=.opswitness
SPLUNK_HEC_URL=
SPLUNK_HEC_TOKEN=
SPLUNK_INDEX=opswitness
SPLUNK_VERIFY_TLS=true
SPLUNK_REQUIRE_HEC=true
# auto confirms indexing when the HEC token supports indexer acknowledgement.
# required fails closed if Splunk cannot confirm indexing; disabled only checks HEC acceptance.
SPLUNK_HEC_ACK_MODE=auto
SPLUNK_HEC_ACK_TIMEOUT_SECONDS=10
SPLUNK_MCP_URL=
SPLUNK_MCP_BEARER_TOKEN=
SPLUNK_OPSWITNESS_APP=opswitness
# Name of a real model discoverable as a Splunk MLTK model. If unset,
# OpsWitness reports hosted-model inference as unavailable.
SPLUNK_HOSTED_MODEL_NAME=
# External Foundation-Sec advisory reasoning. This is not Splunk-hosted
# inference when served by Hugging Face.
FOUNDATION_SEC_ENDPOINT=https://router.huggingface.co/v1/chat/completions
FOUNDATION_SEC_MODEL=fdtn-ai/Foundation-Sec-1.1-8B-Instruct:featherless-ai
FOUNDATION_SEC_API_KEY=
FOUNDATION_SEC_TIMEOUT_SECONDS=60
SLACK_WEBHOOK_URL=
OPSWITNESS_CONSOLE_URL=http://127.0.0.1:3000

# Optional Splunk SOAR execution. Playbooks run only after human approval.
SPLUNK_SOAR_URL=
SPLUNK_SOAR_TOKEN=
SPLUNK_SOAR_CONTAINER_ID=
SPLUNK_SOAR_PLAYBOOK_DEPLOYMENT_REGRESSION=
SPLUNK_SOAR_PLAYBOOK_CREDENTIAL_ATTACK=
SPLUNK_SOAR_PLAYBOOK_QUEUE_SATURATION=

# Optional direct REST/Search API. Splunk Cloud trials may block port 8089.
SPLUNK_BASE_URL=
SPLUNK_AUTH_TOKEN=
SPLUNK_USERNAME=
SPLUNK_PASSWORD=
